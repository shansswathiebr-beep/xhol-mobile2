            t(k) { return this.data[this.lang][k] || k; },
            set(l) {
                this.lang = l;
                document.querySelectorAll('[data-i18n]').forEach(el => {
                    const k = el.getAttribute('data-i18n');
                    if(this.data[l][k]) el.textContent = this.data[l][k];
                });
                localStorage.setItem('xhol-lang', l);
                document.documentElement.lang = l;
            },
            toggle() {
                const langs = ['de', 'en', 'sq', 'ta'];
                const current = langs.indexOf(this.lang);
                const next = langs[(current + 1) % langs.length];
